[meta]
name=JSON
description=JSON metadata for scripting and runtime loading
extension=.json
[/meta]

[header]
{
  "multipack": {{multipack}},
  "scale": {{scale}},
  "extrude": {{extrude}},

[/header]

[atlases]
[atlas_header]
  "atlases": [

[/atlas_header]

[atlas]
    {
      "width": {{atlas_width}},
      "height": {{atlas_height}},
      "path": "{{atlas_path}}"
    }
[/atlas]

[atlas_separator]
,

[/atlas_separator]

[atlas_footer]

  ],
  "sprites": [
    {{sprites}}
  ]
[/atlas_footer]
[/atlases]

[sprites]
  [sprite]
{"name": "{{name}}", "path": "{{path}}", "atlas_index": {{atlas_index}}, "rect": {"x": {{x}}, "y": {{y}}, "w": {{w}}, "h": {{h}}}, "pivot": {"x": {{pivot_x}}, "y": {{pivot_y}}}, "trim": {"left": {{trim_left}}, "top": {{trim_top}}, "right": {{trim_right}}, "bottom": {{trim_bottom}}}, "markers": [{{sprite_markers}}], "rotation": {{rotation}}}
  [/sprite]
[/sprites]

[sprite_marker]
[if marker_type="point"]{"name":"{{marker_name}}","type":"{{marker_type}}","x":{{marker_x}},"y":{{marker_y}}}[/if][if marker_type="circle"]{"name":"{{marker_name}}","type":"{{marker_type}}","x":{{marker_x}},"y":{{marker_y}},"radius":{{marker_radius}}}[/if][if marker_type="rectangle"]{"name":"{{marker_name}}","type":"{{marker_type}}","x":{{marker_x}},"y":{{marker_y}},"w":{{marker_w}},"h":{{marker_h}}}[/if][if marker_type="polygon"]{"name":"{{marker_name}}","type":"{{marker_type}}","vertices":{{marker_vertices}}}[/if]
[/sprite_marker]

[sprite_markers_separator]
,
[/sprite_markers_separator]

[separator]
,

[/separator]

[if_markers]
[/if_markers]

[if has_animations="true"]
,
  "animations": [
[/if]

[animations]
  [animation]
    {"name": "{{animation_name}}"[if is_alias="false"], "fps": {{fps}}, "sprite_indexes": {{sprite_indexes}}, "sprite_names": {{sprite_names}}[/if][if is_alias="true"], "alias": "{{animation_alias}}"[/if][if flip!=""], "flip": "{{flip}}"[/if]}
  [/animation]
[/animations]

[animations_separator]
,
[/animations_separator]

[animations_footer]
  ]
[/animations_footer]

[if has_animations="false"]
[/if]

[footer]
}
[/footer]
